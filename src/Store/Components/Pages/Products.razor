@page "/products"
@using DataEntities
@using Store.Services
@inject IConfiguration Configuration
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@attribute [StreamRendering(true)]

<PageTitle>Products</PageTitle>

<h1>Products</h1>

<p>Here are some of our amazing outdoor products that you can purchase.</p>

@if (products == null)
{
    <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
    </div>
}
else if (!products.Any())
{
    <p>No products found.</p>
}
else
{
    <div class="products-grid">
        @foreach (var p in products)
        {
            <div class="product-card" @onclick="() => NavigateToProduct(p.Id)" role="button" tabindex="0" @onkeydown="(e) => HandleKeyDown(e, p.Id)">
                <div class="product-image">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="@GetFullImageUrl(p.ImageUrl)" alt="@p.Name" />
                    }
                    else
                    {
                        <div class="no-image">No image</div>
                    }
                </div>
                <div class="product-info">
                    <span class="product-name">@p.Name</span>
                    <span class="product-price">@p.Price.ToString("C")</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Product>? products;
    private string imagePrefix = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // small delay to show loading state
        await Task.Delay(300);
        imagePrefix = Configuration["ImagePrefix"] ?? string.Empty;
        products = await ProductService.GetProducts();
    }

    private string GetFullImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl))
            return string.Empty;
        if (string.IsNullOrEmpty(imagePrefix))
            return imageUrl;
        return $"{imagePrefix.TrimEnd('/')}/{imageUrl.TrimStart('/')}";
    }

    private void NavigateToProduct(int productId)
    {
        NavigationManager.NavigateTo($"/product/{productId}");
    }

    private void HandleKeyDown(KeyboardEventArgs e, int productId)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            NavigateToProduct(productId);
        }
    }
}
